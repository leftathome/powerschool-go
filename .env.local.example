# Example .env.local file for 1Password integration
# Copy this to .env.local and fill in your actual 1Password paths
# NEVER commit .env.local to git!

# PowerSchool URL (e.g., https://ps.example.org)
POWERSCHOOL_URL_OP_PATH=op://Private/your-powerschool-item/url

# PowerSchool username
POWERSCHOOL_USERNAME_OP_PATH=op://Private/your-powerschool-item/username

# PowerSchool password
POWERSCHOOL_PASSWORD_OP_PATH=op://Private/your-powerschool-item/password
